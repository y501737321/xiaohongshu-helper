{
  "name": "xiaohongshu-helper",
  "private": true,
  "version": "1.0.0",
  "description": "小红书获客助手 - 专为健身私教设计的自动化获客桌面端软件",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "node scripts/dev.cjs",
    "electron:build": "npm run build && electron-builder --config electron-builder.json",
    "electron:build:mac": "npm run build && electron-builder --config electron-builder.json --mac",
    "electron:build:win": "npm run build && electron-builder --config electron-builder.json --win",
    "package:deps": "node scripts/package-deps.cjs",
    "start": "npm run electron:dev"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.xiaohongshu.helper",
    "productName": "小红书获客助手",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    }
  }
}
